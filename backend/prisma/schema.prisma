generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model to represent both Students and Teachers for FK references.
// (You can split these if you have separate tables, but role-based is common)
model User {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String
  email               String               @unique
  role                String               // e.g., 'student' or 'teacher'
  enrollments         Enrollment[]
  teacherAssignments  TeacherAssignment[]
  uploadedMaterials   StudyMaterial[]
  studentScripts      StudentScript[]      @relation("StudentScripts")
  uploadedScripts     StudentScript[]      @relation("ScriptUploader")

  @@map("users")
}

model Batch {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String
  course              String
  enrollments         Enrollment[]
  teacherAssignments  TeacherAssignment[]
  studyMaterials      StudyMaterial[]
  studentScripts      StudentScript[]

  @@map("batches")
}

enum EnrollmentStatus {
  active
  dropped
  completed
}

model Enrollment {
  id         String           @id @default(uuid()) @db.Uuid
  studentId  String           @db.Uuid @map("student_id")
  batchId    String           @db.Uuid @map("batch_id")
  status     EnrollmentStatus @default(active)
  enrolledAt DateTime         @default(now()) @map("enrolled_at")

  student    User             @relation(fields: [studentId], references: [id])
  batch      Batch            @relation(fields: [batchId], references: [id])

  @@unique([studentId, batchId])
  @@map("enrollments")
}

model TeacherAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  teacherId  String   @db.Uuid @map("teacher_id")
  batchId    String   @db.Uuid @map("batch_id")
  role       String
  assignedAt DateTime @default(now()) @map("assigned_at")

  teacher    User     @relation(fields: [teacherId], references: [id])
  batch      Batch    @relation(fields: [batchId], references: [id])

  @@map("teacher_assignments")
}

model StudyMaterial {
  id         String   @id @db.Uuid
  batchId    String   @db.Uuid @map("batch_id")
  fileName   String   @map("file_name")
  fileType   String   @map("file_type")
  storageUrl String   @map("storage_url")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  uploadedBy String   @db.Uuid @map("uploaded_by")

  batch      Batch    @relation(fields: [batchId], references: [id])
  uploader   User     @relation(fields: [uploadedBy], references: [id])

  @@index([batchId])
  @@index([uploadedBy])
  @@map("study_materials")
}

// FR-17/FR-18: Exam Script Management
// Each evaluated PDF is linked to exactly one student and one batch.
// The binary blob lives in IndexedDB (proxy) / R2 (production); only metadata is stored here.
model StudentScript {
  id         String   @id @db.Uuid
  studentId  String   @db.Uuid @map("student_id")
  batchId    String   @db.Uuid @map("batch_id")
  examName   String   @map("exam_name")
  fileType   String   @default("application/pdf") @map("file_type")
  storageUrl String   @map("storage_url")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  uploadedBy String   @db.Uuid @map("uploaded_by")

  student    User     @relation("StudentScripts", fields: [studentId], references: [id])
  batch      Batch    @relation(fields: [batchId], references: [id])
  uploader   User     @relation("ScriptUploader", fields: [uploadedBy], references: [id])

  @@index([studentId])
  @@index([batchId])
  @@index([uploadedBy])
  @@map("student_scripts")
}
