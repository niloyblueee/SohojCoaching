generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model attendance {
  attendanceid Int       @id @default(autoincrement())
  userid       String?   @db.Uuid
  classdate    DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  ispresent    Boolean?
  users        users?    @relation(fields: [userid], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model batches {
  id                  String                @id @db.Uuid
  name                String
  course              String
  batch_name          String?               @unique
  created_at          DateTime              @default(now())
  monthly_fee         Decimal?              @db.Decimal(10, 2)
  schedule            String?
  subject             String?
  teacher_id          String?               @db.Uuid
  batch_duration      String?
  description         String?
  discounted_fee      Decimal?              @db.Decimal(10, 2)
  weekly_routine      Json?
  users               users?                @relation(fields: [teacher_id], references: [id])
  enrollments         enrollments[]
  student_batches     student_batches[]
  student_scripts     student_scripts[]
  study_materials     study_materials[]
  teacher_assignments teacher_assignments[]
}

model course {
  courseid   Int      @id @default(autoincrement())
  coursename String?  @db.VarChar(255)
  fee        Decimal? @db.Decimal(10, 2)
}

model enrollments {
  id          String           @id @db.Uuid
  student_id  String           @db.Uuid
  batch_id    String           @db.Uuid
  status      EnrollmentStatus @default(active)
  enrolled_at DateTime         @default(now())
  batches     batches          @relation(fields: [batch_id], references: [id])
  users       users            @relation(fields: [student_id], references: [id])

  @@unique([student_id, batch_id])
}

model student_batches {
  userid  String  @db.Uuid
  batchid String  @db.Uuid
  batches batches @relation(fields: [batchid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users   users   @relation(fields: [userid], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([userid, batchid])
}

model student_scripts {
  id                                       String   @id @db.Uuid
  student_id                               String   @db.Uuid
  batch_id                                 String   @db.Uuid
  exam_name                                String
  file_type                                String   @default("application/pdf")
  storage_url                              String
  uploaded_at                              DateTime @default(now())
  uploaded_by                              String   @db.Uuid
  batches                                  batches  @relation(fields: [batch_id], references: [id])
  users_student_scripts_student_idTousers  users    @relation("student_scripts_student_idTousers", fields: [student_id], references: [id])
  users_student_scripts_uploaded_byTousers users    @relation("student_scripts_uploaded_byTousers", fields: [uploaded_by], references: [id])

  @@index([batch_id])
  @@index([student_id])
  @@index([uploaded_by])
}

model study_materials {
  id          String   @id @db.Uuid
  batch_id    String   @db.Uuid
  file_name   String
  file_type   String
  storage_url String
  uploaded_at DateTime @default(now())
  uploaded_by String   @db.Uuid
  batches     batches  @relation(fields: [batch_id], references: [id])
  users       users    @relation(fields: [uploaded_by], references: [id])

  @@index([batch_id])
  @@index([uploaded_by])
}

model teacher_assignments {
  id          String   @id @db.Uuid
  teacher_id  String   @db.Uuid
  batch_id    String   @db.Uuid
  role        String
  assigned_at DateTime @default(now())
  batches     batches  @relation(fields: [batch_id], references: [id])
  users       users    @relation(fields: [teacher_id], references: [id])
}

model users {
  id                                                 String                @id @db.Uuid
  name                                               String
  email                                              String                @unique
  role                                               String
  password_hash                                      String?
  attendance                                         attendance[]
  batches                                            batches[]
  enrollments                                        enrollments[]
  student_batches                                    student_batches[]
  student_scripts_student_scripts_student_idTousers  student_scripts[]     @relation("student_scripts_student_idTousers")
  student_scripts_student_scripts_uploaded_byTousers student_scripts[]     @relation("student_scripts_uploaded_byTousers")
  study_materials                                    study_materials[]
  teacher_assignments                                teacher_assignments[]
}

enum EnrollmentStatus {
  active
  dropped
  completed
}
