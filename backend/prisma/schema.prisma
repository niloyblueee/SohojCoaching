generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String              @id @default(uuid()) @db.Uuid
  name                      String
  email                     String              @unique
  role                      String
  passwordHash              String?             @map("password_hash")
  enrollments               Enrollment[]
  teacherAssignments        TeacherAssignment[]
  configuredBatches         Batch[]             @relation("BatchTeacher")
  uploadedMaterials         StudyMaterial[]
  studentScripts            StudentScript[]     @relation("StudentScripts")
  uploadedScripts           StudentScript[]     @relation("ScriptUploader")
  attendanceSessionsCreated AttendanceSession[] @relation("AttendanceSessionCreator")
  attendanceAsStudent       AttendanceRecord[]  @relation("AttendanceStudent")
  attendanceMarked          AttendanceRecord[]  @relation("AttendanceMarker")

  @@map("users")
}

model Batch {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  course             String
  batchName          String?             @unique @map("batch_name")
  subject            String?
  schedule           String?
  monthlyFee         Decimal?            @map("monthly_fee") @db.Decimal(10, 2)
  discountedFee      Decimal?            @map("discounted_fee") @db.Decimal(10, 2)
  batchDuration      String?             @map("batch_duration")
  description        String?
  weeklyRoutine      Json?               @map("weekly_routine")
  teacherId          String?             @map("teacher_id") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at")
  teacher            User?               @relation("BatchTeacher", fields: [teacherId], references: [id])
  enrollments        Enrollment[]
  teacherAssignments TeacherAssignment[]
  studyMaterials     StudyMaterial[]
  studentScripts     StudentScript[]
  attendanceSessions AttendanceSession[]

  @@map("batches")
}

enum EnrollmentStatus {
  active
  dropped
  completed
}

model Enrollment {
  id         String           @id @default(uuid()) @db.Uuid
  studentId  String           @map("student_id") @db.Uuid
  batchId    String           @map("batch_id") @db.Uuid
  status     EnrollmentStatus @default(active)
  enrolledAt DateTime         @default(now()) @map("enrolled_at")

  student User  @relation(fields: [studentId], references: [id])
  batch   Batch @relation(fields: [batchId], references: [id])

  @@unique([studentId, batchId])
  @@map("enrollments")
}

model TeacherAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  teacherId  String   @map("teacher_id") @db.Uuid
  batchId    String   @map("batch_id") @db.Uuid
  role       String
  assignedAt DateTime @default(now()) @map("assigned_at")

  teacher User  @relation(fields: [teacherId], references: [id])
  batch   Batch @relation(fields: [batchId], references: [id])

  @@map("teacher_assignments")
}

model StudyMaterial {
  id         String   @id @db.Uuid
  batchId    String   @map("batch_id") @db.Uuid
  fileName   String   @map("file_name")
  fileType   String   @map("file_type")
  storageUrl String   @map("storage_url")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  uploadedBy String   @map("uploaded_by") @db.Uuid

  batch    Batch @relation(fields: [batchId], references: [id])
  uploader User  @relation(fields: [uploadedBy], references: [id])

  @@index([batchId])
  @@index([uploadedBy])
  @@map("study_materials")
}

model StudentScript {
  id         String   @id @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  batchId    String   @map("batch_id") @db.Uuid
  examName   String   @map("exam_name")
  fileType   String   @default("application/pdf") @map("file_type")
  storageUrl String   @map("storage_url")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  uploadedBy String   @map("uploaded_by") @db.Uuid

  student  User  @relation("StudentScripts", fields: [studentId], references: [id])
  batch    Batch @relation(fields: [batchId], references: [id])
  uploader User  @relation("ScriptUploader", fields: [uploadedBy], references: [id])

  @@index([studentId])
  @@index([batchId])
  @@index([uploadedBy])
  @@map("student_scripts")
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

model AttendanceSession {
  id          String             @id @default(uuid()) @db.Uuid
  batchId     String             @map("batch_id") @db.Uuid
  sessionDate DateTime           @map("session_date") @db.Date
  topic       String?            @db.VarChar(255)
  createdBy   String?            @map("created_by") @db.Uuid
  createdAt   DateTime           @default(now()) @map("created_at")
  batch       Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  creator     User?              @relation("AttendanceSessionCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  records     AttendanceRecord[]

  @@unique([batchId, sessionDate])
  @@index([batchId])
  @@index([sessionDate])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id        String            @id @default(uuid()) @db.Uuid
  sessionId String            @map("session_id") @db.Uuid
  studentId String            @map("student_id") @db.Uuid
  status    AttendanceStatus  @default(present)
  note      String?
  markedAt  DateTime          @default(now()) @map("marked_at")
  markedBy  String?           @map("marked_by") @db.Uuid
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User              @relation("AttendanceStudent", fields: [studentId], references: [id], onDelete: Cascade)
  marker    User?             @relation("AttendanceMarker", fields: [markedBy], references: [id], onDelete: SetNull)

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@index([status])
  @@index([markedBy])
  @@map("attendance_records")
}

model FeePayment {
  id               String     @id @default(uuid()) @db.Uuid
  enrollmentId     String     @map("enrollment_id") @db.Uuid
  monthNumber      Int        @map("month_number")
  paymentMethod    String?    @db.VarChar(50)  @map("payment_method")
  transactionInfo  String?    @db.VarChar(255) @map("transaction_info")
  paymentDate      DateTime   @default(now())  @map("payment_date")
  recordedBy       String?    @map("recorded_by") @db.Uuid
  amountPaid       Int        @map("amount_paid")

  @@unique([enrollmentId, monthNumber])
  @@index([paymentDate])
  @@index([enrollmentId])
  @@map("fee_payments")
}
