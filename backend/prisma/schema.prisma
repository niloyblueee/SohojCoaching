generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String              @id @default(uuid()) @db.Uuid
  name                      String
  email                     String              @unique
  role                      String
  passwordHash              String?             @map("password_hash")
  status                    String              @default("verified")
  enrollments               Enrollment[]
  teacherAssignments        TeacherAssignment[]
  configuredBatches         Batch[]             @relation("BatchTeacher")
  uploadedMaterials         StudyMaterial[]
  studentScripts            StudentScript[]     @relation("StudentScripts")
  uploadedScripts           StudentScript[]     @relation("ScriptUploader")
  attendanceSessionsCreated AttendanceSession[] @relation("AttendanceSessionCreator")
  attendanceAsStudent       AttendanceRecord[]  @relation("AttendanceStudent")
  attendanceMarked          AttendanceRecord[]  @relation("AttendanceMarker")
  createdQuizzes            Quiz[]              @relation("QuizTeacher")
  quizAttempts              QuizAttempt[]       @relation("QuizAttemptStudent")

  @@map("users")
}

model Batch {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  course             String
  batchName          String?             @unique @map("batch_name")
  subject            String?
  schedule           String?
  monthlyFee         Decimal?            @map("monthly_fee") @db.Decimal(10, 2)
  discountedFee      Decimal?            @map("discounted_fee") @db.Decimal(10, 2)
  batchDuration      String?             @map("batch_duration")
  description        String?
  weeklyRoutine      Json?               @map("weekly_routine")
  teacherId          String?             @map("teacher_id") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at")
  teacher            User?               @relation("BatchTeacher", fields: [teacherId], references: [id])
  enrollments        Enrollment[]
  teacherAssignments TeacherAssignment[]
  studyMaterials     StudyMaterial[]
  studentScripts     StudentScript[]
  attendanceSessions AttendanceSession[]
  quizzes            Quiz[]

  @@map("batches")
}

enum EnrollmentStatus {
  active
  dropped
  completed
}

model Enrollment {
  id         String           @id @default(uuid()) @db.Uuid
  studentId  String           @map("student_id") @db.Uuid
  batchId    String           @map("batch_id") @db.Uuid
  status     EnrollmentStatus @default(active)
  enrolledAt DateTime         @default(now()) @map("enrolled_at")

  student     User         @relation(fields: [studentId], references: [id])
  batch       Batch        @relation(fields: [batchId], references: [id])
  feePayments FeePayment[]
  feeDues     FeeDue[]

  @@unique([studentId, batchId])
  @@map("enrollments")
}

model TeacherAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  teacherId  String   @map("teacher_id") @db.Uuid
  batchId    String   @map("batch_id") @db.Uuid
  role       String
  assignedAt DateTime @default(now()) @map("assigned_at")

  teacher User  @relation(fields: [teacherId], references: [id])
  batch   Batch @relation(fields: [batchId], references: [id])

  @@map("teacher_assignments")
}

model StudyMaterial {
  id         String   @id @db.Uuid
  batchId    String   @map("batch_id") @db.Uuid
  fileName   String   @map("file_name")
  fileType   String   @map("file_type")
  storageUrl String   @map("storage_url")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  uploadedBy String   @map("uploaded_by") @db.Uuid

  batch    Batch @relation(fields: [batchId], references: [id])
  uploader User  @relation(fields: [uploadedBy], references: [id])

  @@index([batchId])
  @@index([uploadedBy])
  @@map("study_materials")
}

model StudentScript {
  id         String   @id @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  batchId    String   @map("batch_id") @db.Uuid
  examName   String   @map("exam_name")
  fileType   String   @default("application/pdf") @map("file_type")
  storageUrl String   @map("storage_url")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  uploadedBy String   @map("uploaded_by") @db.Uuid

  student  User  @relation("StudentScripts", fields: [studentId], references: [id])
  batch    Batch @relation(fields: [batchId], references: [id])
  uploader User  @relation("ScriptUploader", fields: [uploadedBy], references: [id])

  @@index([studentId])
  @@index([batchId])
  @@index([uploadedBy])
  @@map("student_scripts")
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

model AttendanceSession {
  id          String             @id @default(uuid()) @db.Uuid
  batchId     String             @map("batch_id") @db.Uuid
  sessionDate DateTime           @map("session_date") @db.Date
  topic       String?            @db.VarChar(255)
  createdBy   String?            @map("created_by") @db.Uuid
  createdAt   DateTime           @default(now()) @map("created_at")
  batch       Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  creator     User?              @relation("AttendanceSessionCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  records     AttendanceRecord[]

  @@unique([batchId, sessionDate])
  @@index([batchId])
  @@index([sessionDate])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id        String            @id @default(uuid()) @db.Uuid
  sessionId String            @map("session_id") @db.Uuid
  studentId String            @map("student_id") @db.Uuid
  status    AttendanceStatus  @default(present)
  note      String?
  markedAt  DateTime          @default(now()) @map("marked_at")
  markedBy  String?           @map("marked_by") @db.Uuid
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User              @relation("AttendanceStudent", fields: [studentId], references: [id], onDelete: Cascade)
  marker    User?             @relation("AttendanceMarker", fields: [markedBy], references: [id], onDelete: SetNull)

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@index([status])
  @@index([markedBy])
  @@map("attendance_records")
}

model FeePayment {
  id               String     @id @default(uuid()) @db.Uuid
  enrollmentId     String     @map("enrollment_id") @db.Uuid
  monthNumber      Int        @map("month_number")
  paymentMethod    String?    @db.VarChar(50)  @map("payment_method")
  transactionInfo  String?    @db.VarChar(255) @map("transaction_info")
  paymentDate      DateTime   @default(now())  @map("payment_date")
  recordedBy       String?    @map("recorded_by") @db.Uuid
  amountPaid       Int        @map("amount_paid")
  enrollment       Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, monthNumber])
  @@index([paymentDate])
  @@index([enrollmentId])
  @@map("fee_payments")
}

model FeeDue {
  id          String     @id @default(uuid()) @db.Uuid
  enrollmentId String    @map("enrollment_id") @db.Uuid
  monthNumber Int        @map("month_number")
  dueMonth    DateTime   @map("due_month") @db.Date
  amountDue   Int        @map("amount_due")
  status      String     @default("unpaid") @db.VarChar(20)
  generatedAt DateTime   @default(now()) @map("generated_at")
  paidAt      DateTime?  @map("paid_at")
  enrollment  Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, monthNumber])
  @@unique([enrollmentId, dueMonth])
  @@index([dueMonth])
  @@index([status])
  @@index([enrollmentId])
  @@map("fee_dues")
}

model Quiz {
  id               String         @id @default(uuid()) @db.Uuid
  batchId          String         @map("batch_id") @db.Uuid
  teacherId        String         @map("teacher_id") @db.Uuid
  title            String         @db.VarChar(180)
  description      String?
  availabilityType String         @map("availability_type") @db.VarChar(20)
  startsAt         DateTime?      @map("starts_at")
  entryCloseAt     DateTime?      @map("entry_close_at")
  durationMinutes  Int            @map("duration_minutes")
  attemptMode      String         @map("attempt_mode") @db.VarChar(20)
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  batch            Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  teacher          User           @relation("QuizTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  questions        QuizQuestion[]
  attempts         QuizAttempt[]

  @@index([batchId])
  @@index([teacherId])
  @@index([isActive])
  @@index([entryCloseAt])
  @@map("quizzes")
}

model QuizQuestion {
  id                 String   @id @default(uuid()) @db.Uuid
  quizId             String   @map("quiz_id") @db.Uuid
  orderNo            Int      @map("order_no")
  questionType       String   @map("question_type") @db.VarChar(20)
  questionText       String?  @map("question_text")
  questionImageData  String?  @map("question_image_data")
  marks              Int      @default(1)
  mcqOptions         Json?    @map("mcq_options")
  correctOptionIndex Int?     @map("correct_option_index")
  allowFileUpload    Boolean  @default(false) @map("allow_file_upload")
  createdAt          DateTime @default(now()) @map("created_at")
  quiz               Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers            QuizAnswer[]

  @@unique([quizId, orderNo])
  @@index([quizId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id              String      @id @default(uuid()) @db.Uuid
  quizId          String      @map("quiz_id") @db.Uuid
  studentId       String      @map("student_id") @db.Uuid
  attemptNumber   Int         @map("attempt_number")
  status          String      @db.VarChar(20)
  gradingStatus   String      @default("pending") @map("grading_status") @db.VarChar(20)
  totalAwardedMarks Int       @default(0) @map("total_awarded_marks")
  gradedBy        String?     @map("graded_by") @db.Uuid
  gradedAt        DateTime?   @map("graded_at")
  startedAt       DateTime    @default(now()) @map("started_at")
  submittedAt     DateTime?   @map("submitted_at")
  durationMinutes Int         @map("duration_minutes")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  quiz            Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student         User        @relation("QuizAttemptStudent", fields: [studentId], references: [id], onDelete: Cascade)
  answers         QuizAnswer[]

  @@index([quizId])
  @@index([studentId])
  @@index([status])
  @@index([gradingStatus])
  @@unique([quizId, studentId, attemptNumber])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id                     String      @id @default(uuid()) @db.Uuid
  attemptId              String      @map("attempt_id") @db.Uuid
  questionId             String      @map("question_id") @db.Uuid
  mcqSelectedOptionIndex Int?        @map("mcq_selected_option_index")
  broadTextAnswer        String?     @map("broad_text_answer")
  answerFileData         String?     @map("answer_file_data")
  answerFileName         String?     @map("answer_file_name") @db.VarChar(255)
  answerFileType         String?     @map("answer_file_type") @db.VarChar(120)
  awardedMarks           Int?        @map("awarded_marks")
  teacherExplanation     String?     @map("teacher_explanation")
  reviewFileData         String?     @map("review_file_data")
  reviewFileName         String?     @map("review_file_name") @db.VarChar(255)
  reviewFileType         String?     @map("review_file_type") @db.VarChar(120)
  reviewedBy             String?     @map("reviewed_by") @db.Uuid
  reviewedAt             DateTime?   @map("reviewed_at")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")
  attempt                QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question               QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([questionId])
  @@unique([attemptId, questionId])
  @@map("quiz_answers")
}
